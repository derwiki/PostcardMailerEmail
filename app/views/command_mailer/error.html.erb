<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.5;
      color: #333;
      margin: 0;
      padding: 0;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      border-bottom: 1px solid #ddd;
      padding-bottom: 20px;
      margin-bottom: 20px;
    }
    .footer {
      margin-top: 30px;
      padding-top: 20px;
      border-top: 1px solid #ddd;
      font-size: 12px;
      color: #777;
    }
    .alert {
      background-color: #f8d7da;
      border-left: 4px solid #dc3545;
      padding: 15px;
      margin: 20px 0;
    }
    p {
      margin: 0 0 1em 0;
    }
  </style>
</head>

<body>
  <div class="container">
    <div class="header">
      <h1>Error</h1>
    </div>
    
    <p>Hello <%= @email %>,</p>
    
    <div class="alert">
      <p><strong>Error:</strong> <%= @message %></p>
    </div>
    
    <p>If you need assistance, please contact support.</p>
    
    <div class="footer">
      <p>© <%= Date.today.year %> PostcardMailer.us</p>
    </div>
  </div>
</body>
</html> 