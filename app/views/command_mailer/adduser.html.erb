<% content_for :title do %>Recipient Address Added<% end %>

<p style="margin: 0 0 1em 0;">Hello <%= @user.email %>,</p>

<p style="margin: 0 0 1em 0;">We've added <strong style="color: #000;"><%= @new_address.name %></strong> to your PostcardMailer address book.</p>

<div style="background-color: #f5f5f5; padding: 15px; border-radius: 5px; margin: 20px 0;">
  <p style="margin: 0 0 1em 0;"><strong style="color: #000;">Address Details:</strong><br>
  <%= @new_address.address1 %><% if @new_address.address2.present? %>, <%= @new_address.address2 %><% end %><br>
  <%= @new_address.city %>, <%= @new_address.state %> <%= @new_address.postal_code %></p>
</div>

<p style="margin: 0 0 1em 0;">You can now send postcards to this recipient by using their nickname "<strong style="color: #000;"><%= @new_address.nickname %></strong>" in the "to:" field of your postcard emails.</p>

<%= render 'command_mailer/postcard_instructions', address: @new_address %>

<% unless @user.verified? %>
<div style="background-color: #fff3cd; border-left: 4px solid #ffc107; padding: 15px; margin: 20px 0;">
  <p style="margin: 0 0 1em 0;"><strong style="color: #000;">Note:</strong> Your account is still pending verification. While this address has been added to your address book, you'll need to be verified before you can send postcards. We'll notify you once your account has been verified.</p>
</div>
<% end %>

<p style="margin: 0 0 1em 0;">If you did not request this action or have any questions, please contact support.</p>
