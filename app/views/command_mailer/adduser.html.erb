<% content_for :title do %>Recipient Address Added<% end %>

<p class="section">Hello <%= @user.email %>,</p>

<p class="section">We've added <span class="strong"><%= @new_address.name %></span> to your PostcardMailer address book.</p>

<div class="info-box">
  <p class="section"><span class="strong">Address Details:</span><br>
  <%= @new_address.address1 %><% if @new_address.address2.present? %>, <%= @new_address.address2 %><% end %><br>
  <%= @new_address.city %>, <%= @new_address.state %> <%= @new_address.postal_code %></p>
</div>

<p class="section">You can now send postcards to this recipient by using their nickname "<span class="strong"><%= @new_address.nickname %></span>" in the "to:" field of your postcard emails.</p>

<div class="info-box">
  <h3 class="heading">Quick Start Guide</h3>
  <p class="section">To send a postcard:</p>
  <ol class="list">
    <li class="list-item">Email to: <span class="strong"><%= @new_address.nickname %>@postcardmailer.us</span></li>
    <li class="list-item">Subject: Your message to <%= @new_address.name %></li>
    <li class="list-item">Attach: Your postcard image</li>
  </ol>
</div>

<% unless @user.verified? %>
<div class="warning-box">
  <p class="section"><span class="strong">Note:</span> Your account is still pending verification. While this address has been added to your address book, you'll need to be verified before you can send postcards. We'll notify you once your account has been verified.</p>
</div>
<% end %>

<p class="section">If you did not request this action or have any questions, please contact support.</p>
