<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.5;
      color: #333;
      margin: 0;
      padding: 0;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      border-bottom: 1px solid #ddd;
      padding-bottom: 20px;
      margin-bottom: 20px;
    }
    .footer {
      margin-top: 30px;
      padding-top: 20px;
      border-top: 1px solid #ddd;
      font-size: 12px;
      color: #777;
    }
    .alert {
      background-color: #fff3cd;
      border-left: 4px solid #ffc107;
      padding: 15px;
      margin: 20px 0;
    }
    p {
      margin: 0 0 1em 0;
    }
  </style>
</head>

<body>
  <div class="container">
    <div class="header">
      <h1>Recipient Address Added</h1>
    </div>
    
    <p>Hello <%= @user.email %>,</p>
    
    <p>We've added <strong><%= @recipient_email %></strong> to your PostcardMailer address book.</p>

    <p>You can now send postcards to this recipient by using this address in the "to:" field of your postcard emails.</p>
    
    <% unless @user.verified? %>
    <div class="alert">
      <p><strong>Note:</strong> Your account is still pending verification. While this address has been added to your address book, you'll need to be verified before you can send postcards. We'll notify you once your account has been verified.</p>
    </div>
    <% end %>
    
    <p>If you did not request this action or have any questions, please contact support.</p>
    
    <div class="footer">
      <p>© <%= Date.today.year %> PostcardMailer.us</p>
      <% if @user.addresses.first.present? %>
        <p><%= @user.addresses.first.address1 %>, <%= @user.addresses.first.city %>, <%= @user.addresses.first.state %> <%= @user.addresses.first.postal_code %></p>
      <% end %>
    </div>
  </div>
</body>
</html>
