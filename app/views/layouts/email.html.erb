<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.5; color: #333; margin: 0; padding: 0;">
  <div style="max-width: 600px; margin: 0 auto; padding: 20px;">
    <div style="border-bottom: 1px solid #ddd; padding-bottom: 20px; margin-bottom: 20px;">
      <h1 style="margin: 0; color: #333;"><%= content_for?(:title) ? yield(:title) : "PostcardMailer.us" %></h1>
    </div>
    
    <%= yield %>
    
    <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; font-size: 12px; color: #777;">
      <p style="margin: 0 0 1em 0;">© <%= Date.today.year %> PostcardMailer.us</p>
      <p style="margin: 0 0 1em 0;">1198 S Van Ness Ave #40817, San Francisco, CA 94110</p>
    </div>
  </div>
</body>
</html> 