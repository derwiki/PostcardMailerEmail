<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="format-detection" content="telephone=no" />
  <meta name="color-scheme" content="light" />
  <meta name="supported-color-schemes" content="light" />
  <meta name="x-apple-disable-message-reformatting" />
  <meta name="x-apple-mail-display" content="default" />
  <meta name="x-ua-compatible" content="IE=edge" />
  <meta name="x-mailer" content="PostcardMailer" />
  <style>
    /* Base styles */
    body { font-family: Arial, sans-serif; line-height: 1.5; color: #333; margin: 0; padding: 0; -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { border-bottom: 1px solid #ddd; padding-bottom: 20px; margin-bottom: 20px; }
    .header h1 { margin: 0; color: #333; }
    .content { margin: 0; padding: 0; }
    .footer { margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; font-size: 12px; color: #777; }
    .footer p { margin: 0 0 1em 0; }

    /* Common components */
    .section { margin: 0 0 1em 0; }
    .info-box { background-color: #f5f5f5; padding: 15px; border-radius: 5px; margin: 20px 0; }
    .warning-box { background-color: #fff3cd; border-left: 4px solid #ffc107; padding: 15px; margin: 20px 0; }
    .status-box { background-color: #f7f9fc; border-left: 4px solid #4a6ee0; padding: 15px; margin-bottom: 20px; }
    .heading { color: #0066cc; margin-top: 0; }
    .timestamp { color: #888; font-size: 12px; }
    .strong { color: #000; }
    .list { margin-left: 20px; }
    .list-item { margin-bottom: 0.5em; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1><%= content_for?(:title) ? yield(:title) : "PostcardMailer.us" %></h1>
    </div>
    
    <div class="content">
      <%= yield %>
    </div>
    
    <div class="footer">
      <p>© <%= Date.today.year %> PostcardMailer.us</p>
      <p>1198 S Van Ness Ave #40817, San Francisco, CA 94110</p>
    </div>
  </div>
</body>
</html> 